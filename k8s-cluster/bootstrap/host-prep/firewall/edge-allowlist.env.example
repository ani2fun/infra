# Operator-specific firewall settings for vm-1's edge_guardrail nftables
# allowlist. Copy this file to /etc/edge-allowlist.env and fill in the
# placeholder. DO NOT commit the filled-in version to Git.
#
# The edge_guardrail.sh script (in platform/traefik/) reads ADMIN_SSH_ALLOW_IP
# at apply time and embeds it into the nft rule that permits SSH from a
# single home IP. If this value is wrong on rebuild day, you will be locked
# out of SSH on vm-1 -- access will require Contabo's web console.

# The home IP from which the operator administers the cluster. CIDR /32 only.
# Look it up at https://ifconfig.me before applying.
ADMIN_SSH_ALLOW_IP=<<REPLACE_WITH_OPERATOR_HOME_IP>>
